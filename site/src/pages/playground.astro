---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { readFileSync } from 'fs';
import { execSync } from 'child_process';
import { join } from 'path';

const cargoToml = readFileSync(join(process.cwd(), '../Cargo.toml'), 'utf-8');
const version = cargoToml.match(/^version\s*=\s*"([^"]+)"/m)?.[1] ?? 'unknown';
const commit = (() => {
  try { return execSync('git rev-parse --short HEAD', { cwd: process.cwd() }).toString().trim(); }
  catch { return 'unknown'; }
})();

const PHP_VERSIONS = ['8.1', '8.2', '8.3', '8.4', '8.5'];
const DEFAULT_PHP = '8.5';

const EXAMPLES = {
  'type-mismatch': {
    label: 'Type mismatch',
    code: `<?php

function add(int $a, int $b): int {
    return $a + $b;
}

$result = add("not a number", 42);
`,
  },
  'undefined-method': {
    label: 'Undefined method',
    code: `<?php

class User {
    public function getEmail(): string { return ''; }
}

$user = new User();
echo $user->getName();
`,
  },
  'nullability': {
    label: 'Null method call',
    code: `<?php

class User {
    public function name(): string { return ''; }
}

$user = null;
echo $user->name();
`,
  },
  'array-access': {
    label: 'Array access',
    code: `<?php

$counts = ['a' => 1, 'b' => 2];
echo $counts['missing'] + 1;
`,
  },
  'dead-code': {
    label: 'Dead code',
    code: `<?php

function greet(string $name): string {
    return "Hello, $name";
    echo 'never runs';
}

function helper(): void {
    $unused = 42;
}
`,
  },
  'taint': {
    label: 'Taint (SQL)',
    code: `<?php

function run_query(\\mysqli $db): void {
    mysqli_query($db, $_GET['sql']);
}
`,
  },
  'generics': {
    label: 'Generics',
    code: `<?php

/**
 * @template T of int
 * @param T $value
 * @return T
 */
function identity($value) {
    return $value;
}

identity("not an int");
`,
  },
};

const DEFAULT_CODE = EXAMPLES['type-mismatch'].code;
---

<StarlightPage
  frontmatter={{
    title: 'Playground',
    description: 'Try mir in your browser — no install required.',
    tableOfContents: false,
  }}
>
  <div
    class="playground not-content"
    data-base={import.meta.env.BASE_URL.replace(/\/$/, '')}
    data-examples={JSON.stringify(EXAMPLES)}
  >
    <div class="pg-toolbar">
      <div class="pg-drop" id="pg-example-wrap">
        <button type="button" class="pg-drop-btn" aria-haspopup="listbox" aria-expanded="false" aria-label="Example">
          <span class="pg-drop-val">Examples…</span>
          <svg aria-hidden="true" class="pg-drop-caret" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17 9.17a1 1 0 0 0-1.41 0L12 12.71 8.46 9.17a1 1 0 1 0-1.41 1.42l4.24 4.24a1.002 1.002 0 0 0 1.42 0L17 10.59a1.002 1.002 0 0 0 0-1.42Z"/></svg>
        </button>
        <ul class="pg-drop-list" role="listbox" aria-label="Example" hidden>
          {Object.entries(EXAMPLES).map(([k, v]) => (
            <li class="pg-drop-opt" role="option" data-value={k}>{v.label}</li>
          ))}
        </ul>
      </div>
      <div class="pg-drop" id="pg-version-wrap">
        <button type="button" class="pg-drop-btn" aria-haspopup="listbox" aria-expanded="false" aria-label="PHP version">
          <span class="pg-drop-val">PHP {DEFAULT_PHP}</span>
          <svg aria-hidden="true" class="pg-drop-caret" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17 9.17a1 1 0 0 0-1.41 0L12 12.71 8.46 9.17a1 1 0 1 0-1.41 1.42l4.24 4.24a1.002 1.002 0 0 0 1.42 0L17 10.59a1.002 1.002 0 0 0 0-1.42Z"/></svg>
        </button>
        <ul class="pg-drop-list" role="listbox" aria-label="PHP version" hidden>
          {PHP_VERSIONS.map(v => (
            <li class={`pg-drop-opt${v === DEFAULT_PHP ? ' pg-drop-opt--selected' : ''}`} role="option" data-value={v} aria-selected={v === DEFAULT_PHP ? 'true' : 'false'}>{`PHP ${v}`}</li>
          ))}
        </ul>
      </div>
      <button id="pg-btn" class="pg-btn" disabled>Loading…</button>
      <button id="pg-share" class="pg-btn pg-btn--ghost" type="button" title="Copy shareable link">Share</button>
      <span id="pg-status" class="pg-status"></span>
      <span class="pg-meta">mir&nbsp;v{version}&nbsp;·&nbsp;{commit}</span>
    </div>

    <div class="pg-editor">
      <pre id="pg-gutter" class="pg-gutter" aria-hidden="true">1</pre>
      <div class="pg-input-wrap">
        <pre id="pg-highlight" class="pg-highlight" aria-hidden="true"></pre>
        <textarea
          id="pg-input"
          class="pg-input"
          spellcheck="false"
          autocomplete="off"
          autocorrect="off"
          autocapitalize="off"
        >{DEFAULT_CODE}</textarea>
        <div id="pg-overlay" class="pg-overlay" aria-hidden="true">
          <div id="pg-underline" class="pg-underline" style="display:none"></div>
        </div>
      </div>
    </div>

    <div id="pg-diag" class="pg-diag" aria-live="polite"></div>
  </div>
</StarlightPage>

<script is:inline>
  const root      = document.querySelector('.playground');
  const BASE      = root.dataset.base;
  const WASM_JS   = `${BASE}/wasm/mir_wasm.js`;
  const EXAMPLES  = JSON.parse(root.dataset.examples);

  const btn       = document.getElementById('pg-btn');
  const shareBtn  = document.getElementById('pg-share');
  const input     = document.getElementById('pg-input');
  const highlight = document.getElementById('pg-highlight');
  const gutter    = document.getElementById('pg-gutter');
  const editor    = document.querySelector('.pg-editor');
  const diag      = document.getElementById('pg-diag');
  const status    = document.getElementById('pg-status');

  const verWrap  = document.getElementById('pg-version-wrap');
  const verBtn   = verWrap.querySelector('.pg-drop-btn');
  const verList  = verWrap.querySelector('.pg-drop-list');
  const exWrap   = document.getElementById('pg-example-wrap');
  const exBtn    = exWrap.querySelector('.pg-drop-btn');
  const exList   = exWrap.querySelector('.pg-drop-list');

  let pgVersion = verList.querySelector('.pg-drop-opt--selected')?.dataset.value ?? '8.5';

  let playground = null;
  let debounce   = null;

  // ── PHP syntax highlighting ───────────────────────────────────────────────
  function highlightPhp(src) {
    const KW = new Set([
      'abstract','array','as','break','callable','case','catch','class','clone',
      'const','continue','declare','default','do','echo','else','elseif','empty',
      'enum','extends','final','finally','fn','for','foreach','function','goto',
      'if','implements','include','include_once','instanceof','insteadof',
      'interface','isset','list','match','namespace','new','print',
      'private','protected','public','readonly','require','require_once','return',
      'self','parent','static','switch','throw','trait','try','unset','use',
      'var','while','yield',
      // Scalar and return types
      'int','float','string','bool','void','never','mixed','object','iterable',
    ]);
    const CONST = new Set(['null','NULL','true','TRUE','false','FALSE']);

    const parts = [];
    let i = 0;
    let lastKw = '';

    function tok(cls, text) {
      if (cls) parts.push(`<span class="${cls}">${esc(text)}</span>`);
      else parts.push(esc(text));
    }

    while (i < src.length) {
      const rest = src.slice(i);
      let m;

      // PHP open/close tags
      if ((m = /^<\?(?:php\b|=)?/i.exec(rest))) {
        tok('hl-tag', m[0]); i += m[0].length; lastKw = ''; continue;
      }
      if ((m = /^\?>/.exec(rest))) {
        tok('hl-tag', m[0]); i += m[0].length; lastKw = ''; continue;
      }

      // Block comments (including unclosed)
      if (rest.startsWith('/*')) {
        const end = rest.indexOf('*/');
        const s = end === -1 ? rest : rest.slice(0, end + 2);
        tok('hl-comment', s); i += s.length; continue;
      }

      // Line comments
      if ((m = /^\/\/[^\n]*/.exec(rest)) || (m = /^#(?!\[)[^\n]*/.exec(rest))) {
        tok('hl-comment', m[0]); i += m[0].length; continue;
      }

      // Strings — single quoted
      if ((m = /^'(?:[^'\\]|\\.)*'/.exec(rest))) {
        tok('hl-str', m[0]); i += m[0].length; lastKw = ''; continue;
      }
      // Strings — double quoted
      if ((m = /^"(?:[^"\\]|\\.)*"/.exec(rest))) {
        tok('hl-str', m[0]); i += m[0].length; lastKw = ''; continue;
      }
      // Unclosed strings (take to end of line)
      if (rest[0] === "'" || rest[0] === '"') {
        const nl = rest.indexOf('\n');
        const s = nl === -1 ? rest : rest.slice(0, nl);
        tok('hl-str', s); i += s.length; continue;
      }

      // Numbers
      if ((m = /^(?:0[xX][0-9a-fA-F_]+|0[bB][01_]+|0[oO][0-7_]+|\d[\d_]*(?:\.\d[\d_]*)?(?:[eE][+-]?\d+)?)/.exec(rest))) {
        tok('hl-num', m[0]); i += m[0].length; lastKw = ''; continue;
      }

      // $this (special variable)
      if ((m = /^\$this\b/.exec(rest))) {
        tok('hl-this', m[0]); i += m[0].length; lastKw = ''; continue;
      }

      // Variables
      if ((m = /^\$[a-zA-Z_][a-zA-Z0-9_]*/.exec(rest))) {
        tok('hl-var', m[0]); i += m[0].length; lastKw = ''; continue;
      }

      // Identifiers: keywords, constants, class names, function calls
      if ((m = /^[a-zA-Z_\\][a-zA-Z0-9_\\]*/.exec(rest))) {
        const word = m[0];
        if (CONST.has(word)) {
          tok('hl-const', word); lastKw = '';
        } else if (KW.has(word)) {
          tok('hl-kw', word); lastKw = word;
        } else {
          // Check if followed by '(' (skip optional spaces/tabs)
          const after = rest.slice(word.length).replace(/^[ \t]*/, '');
          if (after[0] === '(') {
            tok('hl-fn', word);
          } else if (lastKw === 'new' || lastKw === 'extends' || lastKw === 'instanceof' || /^[A-Z]/.test(word)) {
            tok('hl-type', word);
          } else {
            tok('', word);
          }
          lastKw = '';
        }
        i += word.length; continue;
      }

      // Operators
      if ((m = /^(?:->|=>|::|\?\?=|\?\?|===|!==|<=>|\+\+|--|\.\.\.|[+\-*\/%&|^~<>!=]=?|[?:@])/.exec(rest))) {
        tok('hl-op', m[0]); i += m[0].length; lastKw = ''; continue;
      }

      // Punctuation
      if (/^[{}[\]();,.]/.test(rest[0])) {
        tok('hl-punct', rest[0]); i++; lastKw = ''; continue;
      }

      // Whitespace — preserve, don't clear lastKw so `new Foo` works across spaces
      if ((m = /^\s+/.exec(rest))) {
        parts.push(esc(m[0])); i += m[0].length; continue;
      }

      parts.push(esc(rest[0])); i++;
    }

    return parts.join('') + '\n';
  }

  function updateHighlight() {
    highlight.innerHTML = highlightPhp(input.value);
    highlight.scrollTop  = input.scrollTop;
    highlight.scrollLeft = input.scrollLeft;
  }

  // ── URL share encoding (UTF-8 → base64url) ────────────────────────────────
  function encodeCode(s) {
    return btoa(unescape(encodeURIComponent(s)))
      .replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
  }
  function decodeCode(s) {
    try {
      const pad = '='.repeat((4 - s.length % 4) % 4);
      const b64 = s.replace(/-/g, '+').replace(/_/g, '/') + pad;
      return decodeURIComponent(escape(atob(b64)));
    } catch { return null; }
  }

  function setVersion(v) {
    pgVersion = v;
    verBtn.querySelector('.pg-drop-val').textContent = `PHP ${v}`;
    verList.querySelectorAll('[role="option"]').forEach(o => {
      const s = o.dataset.value === v;
      o.classList.toggle('pg-drop-opt--selected', s);
      o.setAttribute('aria-selected', String(s));
    });
  }

  function readHash() {
    const h = new URLSearchParams(location.hash.slice(1));
    const code = h.get('code');
    const php  = h.get('php');
    if (code) {
      const decoded = decodeCode(code);
      if (decoded != null) input.value = decoded;
    }
    if (php && [...verList.querySelectorAll('[role="option"]')].some(o => o.dataset.value === php)) {
      setVersion(php);
    }
  }
  readHash();

  shareBtn.addEventListener('click', async () => {
    const url = new URL(location.href);
    url.hash = `code=${encodeCode(input.value)}&php=${encodeURIComponent(pgVersion)}`;
    const href = url.toString();
    history.replaceState(null, '', href);
    try {
      await navigator.clipboard.writeText(href);
      const prev = shareBtn.textContent;
      shareBtn.textContent = 'Copied';
      setTimeout(() => { shareBtn.textContent = prev; }, 1200);
    } catch {
      // Clipboard blocked — URL is at least in the address bar now.
    }
  });

  // ── Line numbers + textarea height ───────────────────────────────────────
  function updateGutter() {
    const n = input.value.split('\n').length;
    gutter.textContent = Array.from({ length: n }, (_, i) => i + 1).join('\n');
  }

  function updateInputHeight() {
    input.style.height = 'auto';
    input.style.height = input.scrollHeight + 'px';
  }

  input.addEventListener('input', () => { updateGutter(); updateInputHeight(); });
  updateGutter();
  updateInputHeight();

  // ── Custom dropdowns ──────────────────────────────────────────────────────
  function setupDrop(dropBtn, dropList) {
    const close = () => { dropList.hidden = true; dropBtn.setAttribute('aria-expanded', 'false'); };
    const open  = () => { dropList.hidden = false; dropBtn.setAttribute('aria-expanded', 'true'); };
    dropBtn.addEventListener('click', e => { e.stopPropagation(); dropList.hidden ? open() : close(); });
    document.addEventListener('click', close);
    document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });
    return close;
  }
  const closeVer = setupDrop(verBtn, verList);
  const closeEx  = setupDrop(exBtn, exList);

  verList.addEventListener('click', e => {
    const opt = e.target.closest('[role="option"]');
    if (!opt) return;
    setVersion(opt.dataset.value);
    closeVer();
    runAnalysis();
  });

  // ── Examples ──────────────────────────────────────────────────────────────
  exList.addEventListener('click', e => {
    const opt = e.target.closest('[role="option"]');
    if (!opt) return;
    const ex = EXAMPLES[opt.dataset.value];
    if (!ex) return;
    input.value = ex.code;
    exBtn.querySelector('.pg-drop-val').textContent = 'Examples…';
    closeEx();
    updateGutter();
    updateInputHeight();
    updateHighlight();
    runAnalysis();
  });

  // ── WASM ──────────────────────────────────────────────────────────────────
  async function loadWasm() {
    try {
      const mod = await import(WASM_JS);
      await mod.default();
      playground = new mod.Playground();
      btn.textContent = 'Analyze';
      btn.disabled = false;
      runAnalysis();
    } catch (e) {
      status.textContent = 'Failed to load analyzer.';
      console.error(e);
    }
  }

  function esc(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  // ── Overlay highlight ─────────────────────────────────────────────────────
  const overlay    = document.getElementById('pg-overlay');
  const underline  = document.getElementById('pg-underline');

  let charW = null;
  function getCharWidth() {
    if (charW) return charW;
    const canvas = document.createElement('canvas');
    const ctx = canvas.getContext('2d');
    ctx.font = getComputedStyle(input).font;
    charW = ctx.measureText('x').width;
    return charW;
  }

  function positionUnderline() {
    if (!underline._issue) return;
    const { line, colStart, colEnd, sev } = underline._issue;
    const computed  = getComputedStyle(input);
    const lineH     = parseFloat(computed.lineHeight) || 22;
    const padTop    = parseFloat(computed.paddingTop)  || 16;
    const padLeft   = parseFloat(computed.paddingLeft) || 16;
    const cw        = getCharWidth();
    const lineText  = input.value.split('\n')[line - 1] ?? '';
    const endCol    = colEnd > 0 ? colEnd : lineText.length;

    const top   = padTop + (line - 1) * lineH + lineH - 4 - input.scrollTop;
    const left  = padLeft + (colStart - 1) * cw - input.scrollLeft;
    const width = Math.max(cw * 2, (endCol - colStart) * cw);

    const colors = { error: 'var(--mir-error)', warning: 'var(--mir-warning)', info: 'var(--mir-gold)' };
    underline.style.cssText = `display:block; top:${top}px; left:${left}px; width:${width}px; border-color:${colors[sev] ?? colors.error};`;
    overlay.scrollTop  = input.scrollTop;
    overlay.scrollLeft = input.scrollLeft;
  }

  input.addEventListener('scroll', () => {
    highlight.scrollLeft = input.scrollLeft;
    positionUnderline();
  });

  function paintFromCard(card) {
    const sev = card.classList.contains('pg-issue--error') ? 'error'
              : card.classList.contains('pg-issue--warning') ? 'warning' : 'info';
    underline._issue = {
      line: +card.dataset.line, lineEnd: +card.dataset.lineEnd,
      colStart: +card.dataset.colStart, colEnd: +card.dataset.colEnd, sev,
    };
    positionUnderline();
  }

  // Hover: paint underline only (no scroll). Click: also scroll the textarea.
  diag.addEventListener('mouseover', e => {
    const card = e.target.closest('.pg-issue');
    if (card) paintFromCard(card);
  });
  diag.addEventListener('click', e => {
    const card = e.target.closest('.pg-issue');
    if (!card) return;
    paintFromCard(card);
    const lineH = parseFloat(getComputedStyle(input).lineHeight) || 22;
    editor.scrollTop = Math.max(0, (+card.dataset.line - 1) * lineH - editor.clientHeight / 3);
    input.focus();
  });
  diag.addEventListener('mouseleave', () => {
    underline._issue = null;
    underline.style.display = 'none';
  });

  function renderIssues(issues) {
    if (!issues.length) {
      diag.innerHTML = '<p class="pg-empty">No issues found.</p>';
      return;
    }
    diag.innerHTML = issues.map(i => {
      const s = i.severity.toLowerCase();
      return `<div class="pg-issue pg-issue--${s}"
          data-line="${i.line}" data-line-end="${i.line_end}"
          data-col-start="${i.col_start}" data-col-end="${i.col_end}">
        <div class="pg-issue-head">
          <span class="pg-dot"></span>
          <span class="pg-issue-name">${esc(i.name)}</span>
          <span class="pg-issue-loc">line&nbsp;${i.line}:${i.col_start}</span>
        </div>
        <div class="pg-issue-msg">${esc(i.message)}</div>
      </div>`;
    }).join('');
  }

  function runAnalysis() {
    if (!playground) return;
    try {
      renderIssues(JSON.parse(playground.analyze(input.value, pgVersion)));
    } catch (e) {
      diag.innerHTML = '<p class="pg-empty">Analysis error.</p>';
      console.error(e);
    }
  }

  btn.addEventListener('click', runAnalysis);
  input.addEventListener('input', () => {
    updateHighlight();
    clearTimeout(debounce);
    debounce = setTimeout(runAnalysis, 400);
  });

  updateHighlight();
  loadWasm();
</script>
