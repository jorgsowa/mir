#!/usr/bin/env php
<?php
/**
 * Shim that forwards execution to the prebuilt mir binary downloaded by
 * Mir\Composer\Installer at composer install/update time.
 *
 * Uses proc_open with an argv array (PHP 7.4+, including Windows on PHP 8.0+)
 * so arguments are passed without going through a shell — no quoting bugs,
 * no command injection surface from caller-controlled argv.
 */

declare(strict_types=1);

// Load the Composer autoloader so Installer and InstalledVersions are available.
if (!class_exists(\Composer\InstalledVersions::class, false)) {
    $loaded = false;
    foreach ([
        __DIR__ . '/../../../../autoload.php',
        __DIR__ . '/../../vendor/autoload.php',
    ] as $autoload) {
        if (file_exists($autoload)) {
            require $autoload;
            $loaded = true;
            break;
        }
    }
    if (!$loaded) {
        fwrite(STDERR, "mir: Composer autoloader not found. Run `composer install` first.\n");
        exit(1);
    }
}

$packageRoot = dirname(__DIR__, 2);
$binaryName = PHP_OS_FAMILY === 'Windows' ? 'mir.exe' : 'mir';
$binary = $packageRoot . DIRECTORY_SEPARATOR . 'bin' . DIRECTORY_SEPARATOR . $binaryName;

// Ensure the binary for the current platform is present. If the stored binary
// was built for a different platform (e.g. a macOS binary in an Alpine container)
// Installer::run() detects the marker mismatch and re-downloads the correct one.
try {
    \Mir\Composer\Installer::run(
        static fn(string $msg) => fwrite(STDERR, "mir: {$msg}\n"),
        static fn(string $msg) => fwrite(STDERR, "mir: warning: {$msg}\n"),
    );
} catch (\RuntimeException $e) {
    fwrite(STDERR, "mir: {$e->getMessage()}\n");
    exit(1);
}

if (!is_file($binary)) {
    fwrite(
        STDERR,
        "mir: prebuilt binary not found at {$binary}.\n"
        . "Run `composer install` to fetch it.\n",
    );
    exit(1);
}

if (PHP_OS_FAMILY !== 'Windows' && !is_executable($binary)) {
    @chmod($binary, 0755);
}

$argv = array_merge([$binary], array_slice($_SERVER['argv'], 1));
$descriptors = [
    0 => ['file', 'php://stdin', 'r'],
    1 => ['file', 'php://stdout', 'w'],
    2 => ['file', 'php://stderr', 'w'],
];

$proc = proc_open($argv, $descriptors, $pipes);
if (!is_resource($proc)) {
    $os = PHP_OS_FAMILY;
    $arch = php_uname('m');
    fwrite(
        STDERR,
        "mir: failed to launch {$binary}.\n"
        . "The binary may have been built for a different platform (current: {$os} {$arch}).\n"
        . "Delete {$binary} and run `composer install` to re-download the correct binary.\n",
    );
    exit(1);
}

$status = proc_close($proc);
exit($status === -1 ? 1 : $status);
